<clickhouse>
    <!--
        CORS configuration for the demo web UI.
        Browser-side ClickHouse queries (e.g. @clickhouse/client-web) require
        a working CORS preflight response. This is a permissive demo setup —
        in production, restrict Access-Control-Allow-Origin to a known origin.
    -->
    <http_options_response>
        <header>
            <name>Access-Control-Allow-Origin</name>
            <value>*</value>
        </header>
        <header>
            <name>Access-Control-Allow-Methods</name>
            <value>GET, POST, OPTIONS</value>
        </header>
        <header>
            <name>Access-Control-Allow-Headers</name>
            <value>origin, x-requested-with, x-clickhouse-user, x-clickhouse-key, x-clickhouse-database, x-clickhouse-format, x-clickhouse-summary, content-type, authorization</value>
        </header>
        <header>
            <name>Access-Control-Max-Age</name>
            <value>86400</value>
        </header>
    </http_options_response>
</clickhouse>
